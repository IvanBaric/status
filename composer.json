{
  "name": "ivanbaric/status",
  "description": "Morph-based status management for Laravel models with history and cached status lookups.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/database": "^11.0 || ^12.0 || ^13.0",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "IvanBaric\\Status\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IvanBaric\\Status\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
    "pestphp/pest": "^3.0 || ^4.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "IvanBaric\\Status\\StatusServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
